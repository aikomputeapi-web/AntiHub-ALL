# ========== Images ==========
IMAGE_OWNER=zhongruan0522
IMAGE_TAG=latest

# ========== Ports (Host -> Container) ==========
WEB_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# ========== Web ==========
# Cookie Protocol: HTTPS or HTTP (Change to HTTP if using direct IP connection over HTTP)
COOKIE_HTTP=HTTPS
# Internal address for web container to access backend; empty = infer automatically
BACKEND_INTERNAL_URL=

# ========== PostgreSQL (bundled with compose) ==========
# If using `docker-compose.core.yml` (without postgres), change host to host.docker.internal / your internal network address
POSTGRES_USER=antihub
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=antihub
DATABASE_URL=postgresql+asyncpg://antihub:please-change-me@postgres:5432/antihub

# ========== Redis ==========
# If using `docker-compose.core.yml` (without redis), change this to your own Redis address
REDIS_URL=redis://redis:6379/0

# ========== Backend Required ==========
JWT_SECRET_KEY=please-change-me
# Fernet key (32 bytes urlsafe base64); MUST be changed for production
# Generate with: docker compose run --rm backend python generate_encryption_key.py
PLUGIN_API_ENCRYPTION_KEY=STAdjfQFXLnk2-2Vd8WaGPr0OJ4h_Cvk91WCcpds7G8=
DEBUG_LOG=false
# Usage logs request headers redaction (Authorization/Cookie/Token etc.)
# true=save redacted request headers; false=save full request headers (only recommended for single-admin/personal deployment)
USAGE_LOG_REDACT_HEADERS=true

# ========== Codex (Optional) ==========
# CODEX_SUPPORTED_MODELS: JSON array or comma separated; empty = use built-in list
CODEX_SUPPORTED_MODELS=
CODEX_API_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_PROXY_URL=

# ========== Kiro (Optional) ==========
KIRO_IDE_VERSION=0.9.2
KIRO_PROXY_URL=

# ========== Antigravity OAuth (Optional; empty = use built-in defaults) ==========
# Usage: Login/import for Antigravity (cloudcode-pa) accounts (OAuth code -> refresh_token).
# Default callback port reference CLIProxyAPIPlus: 51121
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_REDIRECT_URI=http://localhost:51121/oauth-callback
ANTIGRAVITY_OAUTH_SCOPE=

# ========== Gemini CLI OAuth (Optional; empty = use built-in defaults) ==========
GEMINI_CLI_OAUTH_CLIENT_ID=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
GEMINI_CLI_OAUTH_REDIRECT_URI=http://localhost:8085/oauth2callback
GEMINI_CLI_OAUTH_SCOPE=

# ========== Admin Account (Optional; auto-created on first start; empty = don't create) ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-me-to-strong-password

# ========== ZAI TTS (Optional) ==========
ZAI_TTS_BASE_URL=https://audio.z.ai
ZAI_TTS_FILE_KEEP_COUNT=10

# ========== ZAI Image (Optional) ==========
ZAI_IMAGE_BASE_URL=https://image.z.ai
ZAI_IMAGE_USER_AGENT=
